---
import Layout from "../layouts/Layout.astro";
import Typewriter from "../components/Typewriter.jsx";
import ProjectGrid from "../components/ProjectGrid.jsx";
import ExperienceCarousel from "../components/ExperienceCarousel.jsx";
import Footer from "../components/Footer.jsx";
import "../styles/projectCard.scss";

const links = [
  {
    name: "LinkedIn",
    url: "https://www.linkedin.com/in/maxence-debes",
    icon: "/icons/linkedin.svg",
  },
  {
    name: "GitHub",
    url: "https://github.com/maxencedbe",
    icon: "/icons/github.svg",
  },
  {
    name: "Mail",
    url: "mailto:maxence.debes@polytechnique.edu",
    icon: "/icons/mail.svg",
  },
];

const roles = ["Machine Learning Student"];

const workExperience = [
  {
    title: "ChemAI",
    date: "Apr 2026 – Oct 2026",
    role: "Data Science Intern",
    icon: "/ChemAI.png",
    logoClass: "scale-[1.4]"
  },
  {
    title: "Batigere Maison Familiale",
    date: "Jul 2025 – Aug 2025",
    role: "IT Intern",
    icon: "/Batigere.png",
  },
  {
    title: "Atos",
    date: "Jul 2024 – Aug 2024",
    role: "Java Programmer Intern",
    icon: "/Atos.png",
  },
];

const education = [
  {
    title: "École Polytechnique - Polytechnic Institute of Paris",
    date: "Sep 2025 – Present",
    role: "MSc Data Science",
    icon: "/X.png",
    url: "https://www.ip-paris.fr/education/masters/mention-mathematiques-appliquees-statistique/master-year-2-data-science",
  },
  {
    title: "Télécom SudParis - Polytechnic Institute of Paris",
    date: "Sep 2023 – Present",
    role: "Master's degree in Computer Science and Applied Mathematics",
    icon: "/TSP.png",
    logoClass: "scale-[1.2]",
    url: "https://www.telecom-sudparis.eu/formation/modelisations-statistiques-et-applications/",
  },
];
---

<Layout title="Maxence Debes">
  <!-- ═══════════════════ HERO ═══════════════════ -->
  <section
    id="home"
    class="relative flex flex-col items-center justify-center w-full px-4 sm:px-6 md:px-8 lg:px-12 h-[calc(100svh-65px)] md:h-[calc(100svh-120px)]"
  >
    <div
      class="flex flex-col lg:flex-row items-center justify-center w-full max-w-6xl gap-8 md:gap-16 lg:gap-32 xl:gap-40"
    >
      <div
        class="w-full lg:w-auto flex flex-col items-stretch lg:items-start text-center lg:text-left reveal-up"
      >
        <h1
          class="text-3xl sm:text-5xl md:text-6xl font-bold text-black dark:text-white"
        >
          Maxence Debes
        </h1>
        <p
          class="mt-1 sm:mt-5 text-lg sm:text-2xl md:text-3xl text-black dark:text-white lg:pl-[2px]"
        >
          <span
            class="text-pink-400 font-semibold"
          >
            <Typewriter client:load words={roles} />
          </span>
        </p>
      </div>

      <div
        class="flex justify-center items-center mt-2 lg:mt-0 reveal-scale reveal-delay-200"
      >
        <div
          class="w-40 sm:w-50 md:w-60 lg:w-72 aspect-square rounded-full border border-black/20 dark:border-white/20 overflow-hidden"
        >
          <img
            src="/Profile_picture.jpg"
            alt="Photo"
            class="w-full h-full object-cover scale-135 lg:translate-x-5 lg:translate-y-7 translate-x-3 translate-y-3 transition-transform duration-500 hover:scale-[1.40]"
          />
        </div>
      </div>
    </div>

    <div class="flex justify-center mt-12 lg:mt-16 mb-8 lg:mb-16">
      <div class="contact-buttons">
        {
          links.map((link, index) => (
            <div
              class="reveal-up reveal-early"
              style={{ transitionDelay: `${400 + index * 100}ms` }}
            >
              <a
                href={link.url}
                target="_blank"
                rel="noopener noreferrer"
                class="contact-button"
              >
                <img src={link.icon} alt={link.name} />
              </a>
            </div>
          ))
        }
      </div>
    </div>

    {/* Scroll Indicator */}
    <div class="absolute bottom-4 sm:bottom-8 left-1/2 -translate-x-1/2">
      <div
        class="flex flex-col items-center gap-2 reveal-up reveal-early"
        style={{ transitionDelay: "800ms" }}
      >
        <span
          class="text-xs font-bold tracking-widest text-black dark:text-white uppercase"
          >Scroll</span
        >

        {/* Scroll Mouse (Desktop) */}
        <div
          class="hidden sm:flex w-[30px] h-[50px] border-[1.5px] border-black/10 dark:border-white/15 rounded-full justify-center p-1"
        >
          <div class="w-1 h-2.5 bg-pink-400 rounded-full animate-bounce"></div>
        </div>

        {/* Scroll Arrow (Mobile) */}
        <div class="flex sm:hidden text-pink-400 animate-bounce mt-1">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="2.5"
            stroke="currentColor"
            class="w-6 h-6"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M19.5 8.25l-7.5 7.5-7.5-7.5"></path>
          </svg>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════ ABOUT ═══════════════════ -->
  <section
    id="about"
    class="px-6 md:px-12 text-black dark:text-white pt-24 pb-20 mt-12 sm:mt-24 section-bg-reveal"
  >
    <div class="max-w-[1100px] mx-auto">
      <div class="mb-2 text-center reveal-up">
        <span class="text-xs font-bold tracking-widest text-pink-400 uppercase"
          >About me</span
        >
      </div>
      <h2
        class="text-4xl font-bold text-black dark:text-white mb-8 md:mb-10 text-center reveal-up reveal-delay-100"
      >
        About me
      </h2>

      <p
        class="text-base sm:text-lg leading-relaxed mb-6 text-justify desktop-indent mobile-narrow text-black dark:text-white reveal-up reveal-delay-200"
      >
        I am Maxence Debes, an MSc Data Science student with a strong background
        in Mathematics and Computer Science. I am passionate about Machine
        Learning, software development, and how technology can drive digital
        transformation.
      </p>
    </div>

    <div class="max-w-[1100px] mx-auto mb-20">
      <h2
        class="text-2xl font-semibold mb-8 section-title text-black dark:text-white reveal-up reveal-delay-100"
      >
        Work experience
      </h2>

      <div class="reveal-up reveal-delay-200 w-full mb-16 md:mb-20">
        <ExperienceCarousel client:load items={workExperience} />
      </div>

      <h2
        class="text-2xl font-semibold mb-8 section-title text-black dark:text-white reveal-up reveal-delay-100"
      >
        Skills & interests
      </h2>

      <div class="flex flex-col lg:flex-row gap-6 items-stretch w-full">
        <div class="flex-[1.1] w-full reveal-up reveal-delay-200">
          <div class="glass-card p-6 h-full">
            <svg
              class="about-border"
              xmlns="http://www.w3.org/2000/svg"
              aria-hidden="true"
            >
              <rect x="0" y="0" width="100%" height="100%" rx="20" ry="20"
              ></rect>
            </svg>
            <h3
              class="text-lg font-semibold mb-4 text-black dark:text-white relative z-10"
            >
              Data Science & AI
            </h3>
            <div class="flex flex-wrap gap-2 relative z-10">
              {
                [
                  { name: "Python", icon: "https://cdn.simpleicons.org/python" },
                  { name: "PyTorch", icon: "https://cdn.simpleicons.org/pytorch" },
                  { name: "Pandas", icon: "https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/pandas/pandas-original.svg" },
                  { name: "Transformers", icon: "https://cdn.simpleicons.org/huggingface" },
                  { name: "Scikit-learn", icon: "https://cdn.simpleicons.org/scikitlearn" },
                ].map((skill) => (
                  <span class="px-3 py-1 text-sm font-medium rounded-full bg-black/5 dark:bg-white/10 text-black dark:text-white border border-black/5 dark:border-white/5 inline-flex items-center gap-1.5">
                    <img src={skill.icon} alt="" class="w-3.5 h-3.5 grayscale" aria-hidden="true" />
                    {skill.name}
                  </span>
                ))
              }
            </div>
          </div>
        </div>

        <div class="flex-[0.85] w-full reveal-up reveal-delay-300">
          <div class="glass-card p-6 h-full">
            <svg
              class="about-border"
              xmlns="http://www.w3.org/2000/svg"
              aria-hidden="true"
            >
              <rect x="0" y="0" width="100%" height="100%" rx="20" ry="20"
              ></rect>
            </svg>
            <h3
              class="text-lg font-semibold mb-4 text-black dark:text-white relative z-10"
            >
              Programming & tools
            </h3>
            <div class="flex flex-wrap gap-2 relative z-10">
              {
                [
                  { name: "Linux", icon: "https://cdn.simpleicons.org/linux" },
                  { name: "LaTeX", icon: "https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/latex/latex-original.svg" },
                  { name: "Git", icon: "https://cdn.simpleicons.org/git" },
                  { name: "Java", icon: "https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/java/java-original.svg" },
                  { name: "SQL", icon: "inline-db" },
                ].map((skill) => (
                  <span class="px-3 py-1 text-sm font-medium rounded-full bg-black/5 dark:bg-white/10 text-black dark:text-white border border-black/5 dark:border-white/5 inline-flex items-center gap-1.5">
                    {skill.icon === "inline-db" ? (
                      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-3.5 h-3.5" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 6.375c0 2.278-3.694 4.125-8.25 4.125S3.75 8.653 3.75 6.375m16.5 0c0-2.278-3.694-4.125-8.25-4.125S3.75 4.097 3.75 6.375m16.5 0v11.25c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125V6.375m16.5 5.625c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125" />
                      </svg>
                    ) : skill.icon ? (
                      <img src={skill.icon} alt="" class="w-3.5 h-3.5 grayscale" aria-hidden="true" />
                    ) : null}
                    {skill.name}
                  </span>
                ))
              }
            </div>
          </div>
        </div>

        <div class="flex-1 w-full reveal-up reveal-delay-400">
          <div class="glass-card p-6 h-full">
            <svg
              class="about-border"
              xmlns="http://www.w3.org/2000/svg"
              aria-hidden="true"
            >
              <rect x="0" y="0" width="100%" height="100%" rx="20" ry="20"
              ></rect>
            </svg>
            <h3
              class="text-lg font-semibold mb-4 text-black dark:text-white relative z-10"
            >
              Languages
            </h3>
            <div class="flex flex-wrap gap-2 relative z-10">
              <span class="px-3 py-1 text-sm font-medium rounded-full bg-black/5 dark:bg-white/10 text-black dark:text-white border border-black/5 dark:border-white/5 inline-flex items-center gap-1.5"><span class="grayscale">🇫🇷</span> French (native)</span>
              <span class="px-3 py-1 text-sm font-medium rounded-full bg-black/5 dark:bg-white/10 text-black dark:text-white border border-black/5 dark:border-white/5 inline-flex items-center gap-1.5"><span class="grayscale">🇬🇧</span> English (C1)</span>
              <span class="px-3 py-1 text-sm font-medium rounded-full bg-black/5 dark:bg-white/10 text-black dark:text-white border border-black/5 dark:border-white/5 inline-flex items-center gap-1.5"><span class="grayscale">🇩🇪</span> German (A2)</span>
            </div>
          </div>
        </div>
      </div>
      <div class="w-full h-16 md:h-20"></div>

      <h2
        class="text-2xl font-semibold mb-8 section-title text-black dark:text-white reveal-up reveal-delay-100"
      >
        Education
      </h2>

      <div class="reveal-up reveal-delay-200 w-full">
        <ExperienceCarousel client:load items={education} />
      </div>
    </div>
  </section>

  <!-- ═══════════════════ PROJECTS ═══════════════════ -->
  <section id="projects" class="pt-24 pb-20">
    <main class="flex flex-col items-center px-4 w-full mx-auto">
      <div
        class="max-w-[1280px] lg:max-w-[1162px] mx-auto pb-6 px-4 sm:px-6 md:px-8"
      >
        <div class="mb-2 text-center reveal-up">
          <span
            class="text-xs font-bold tracking-widest text-pink-400 uppercase"
            >My projects</span
          >
        </div>
        <h2
          class="text-4xl font-bold text-black dark:text-white text-center md:mb-10 mb-8 reveal-up reveal-delay-100"
        >
          My projects
        </h2>

        <p
          class="text-base sm:text-lg leading-relaxed text-justify desktop-indent mobile-narrow mb-6 md:mb-8 text-black dark:text-white reveal-up reveal-delay-200"
        >
          Here you will find a selection of projects I have worked on, ranging
          from academic research to personal and professional experiences. Each
          one reflects my interest in AI, data, and software development.
          Whenever possible, I have included links to repositories so you can
          explore the work in more detail. Some projects are still under
          development, as I am continuously improving them.
        </p>
      </div>
      <div
        class="max-w-[1280px] lg:max-w-[1162px] mx-auto px-4 sm:px-6 md:px-8 w-full"
      >
        <ProjectGrid client:load />
      </div>
    </main>
  </section>

  <!-- ═══════════════════ CONTACT ═══════════════════ -->
  <section
    id="contact"
    class="pt-24 pb-0 min-h-svh flex flex-col section-bg-reveal"
  >
    <div
      class="max-w-[1100px] w-full mx-auto px-6 md:px-12 flex flex-col items-center flex-grow relative z-10"
    >
      <div class="mb-2 text-center reveal-up">
        <span class="text-xs font-bold tracking-widest text-pink-400 uppercase"
          >Let's connect</span
        >
      </div>
      <h2
        class="text-4xl md:text-5xl font-bold text-black dark:text-white mb-6 md:mb-12 text-center reveal-up reveal-delay-100"
      >
        Let's connect
      </h2>

      <div class="w-full py-8">
      <div
        class="flex flex-col md:flex-row items-center md:items-stretch gap-12 md:gap-20 w-full"
      >
        {/* Left Column: Context & Status */}
        <div
          class="w-full md:w-1/2 flex flex-col justify-center reveal-right reveal-delay-200"
        >
          <p
            class="text-base sm:text-lg leading-relaxed text-black/80 dark:text-white mb-8 max-w-lg"
          >
            Whether you have a question, a project idea, or just want to chat
            about AI, software engineering, and the future of tech, my inbox is
            always open. I'll do my best to get back to you!
          </p>

          <div
            class="flex items-center gap-3 w-fit"
          >
            <span class="relative flex h-3 w-3">
              <span
                class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"
              ></span>
              <span
                class="relative inline-flex rounded-full h-3 w-3 bg-green-500"
              ></span>
            </span>
            <span
              class="text-xs sm:text-sm font-semibold tracking-wide text-black/70 dark:text-white"
            >
              Open to new opportunities
            </span>
          </div>
        </div>

        <div
          class="w-full md:w-1/2 max-w-lg mx-auto md:mx-0 reveal-left reveal-delay-400"
        >
          <form
            id="contact-form"
            action="https://api.web3forms.com/submit"
            method="POST"
            class="flex flex-col gap-5 bg-[rgba(255,255,255,0.9)] dark:bg-[rgba(0,0,0,0.85)] backdrop-blur-[20px] dark:backdrop-blur-[2px] border border-[rgba(0,0,0,0.1)] dark:border-[rgba(255,255,255,0.15)] shadow-[0_3px_6px_rgba(0,0,0,0.05),0_8px_15px_rgba(0,0,0,0.1)] dark:shadow-none p-6 sm:p-8 rounded-2xl transition-all"
          >
            <input
              type="hidden"
              name="access_key"
              value="b7a332b3-794a-40fe-999e-e85a68145764"
            />
            <input
              type="hidden"
              name="subject"
              value="New message from your Portfolio"
            />
            <input
              type="checkbox"
              name="botcheck"
              class="hidden"
              style="display: none;"
            />

            <div class="flex flex-col gap-1.5">
              <label
                for="name"
                class="text-xs tracking-wide text-black dark:text-white ml-1"
                >Name</label
              >
              <input
                type="text"
                id="name"
                name="name"
                required
                autocomplete="none"
                oninvalid="this.setCustomValidity('Please fill out this field.')"
                oninput="this.setCustomValidity('')"
                class="w-full bg-[rgba(0,0,0,0.02)] dark:bg-[rgba(255,255,255,0.05)] border border-[rgba(0,0,0,0.05)] dark:border-[rgba(255,255,255,0.1)] rounded-xl px-4 py-3 text-black dark:text-white placeholder:text-black/30 dark:placeholder:text-white/30 focus:outline-none transition-all font-medium text-sm"
              />
            </div>

            <div class="flex flex-col gap-1.5">
              <label
                for="email"
                class="text-xs tracking-wide text-black dark:text-white ml-1"
                >Email</label
              >
              <input
                type="email"
                id="email"
                name="email"
                required
                autocomplete="none"
                oninvalid="this.setCustomValidity('Please enter a valid email address.')"
                oninput="this.setCustomValidity('')"
                class="w-full bg-[rgba(0,0,0,0.02)] dark:bg-[rgba(255,255,255,0.05)] border border-[rgba(0,0,0,0.05)] dark:border-[rgba(255,255,255,0.1)] rounded-xl px-4 py-3 text-black dark:text-white placeholder:text-black/30 dark:placeholder:text-white/30 focus:outline-none transition-all font-medium text-sm"
              />
            </div>

            <div class="flex flex-col gap-1.5">
              <label
                for="message"
                class="text-xs tracking-wide text-black dark:text-white ml-1"
                >Message</label
              >
              <textarea
                id="message"
                name="message"
                required
                autocomplete="none"
                oninvalid="this.setCustomValidity('Please fill out this field.')"
                oninput="this.setCustomValidity('')"
                rows="4"
                class="w-full bg-[rgba(0,0,0,0.02)] dark:bg-[rgba(255,255,255,0.05)] border border-[rgba(0,0,0,0.05)] dark:border-[rgba(255,255,255,0.1)] rounded-xl px-4 py-3 text-black dark:text-white placeholder:text-black/30 dark:placeholder:text-white/30 focus:outline-none transition-all font-medium text-sm resize-none"
              ></textarea>
            </div>

            <button
              id="submit-button"
              type="submit"
              class="mt-2 w-full flex items-center justify-center gap-2 px-6 py-3.5 bg-[rgba(0,0,0,0.02)] dark:bg-[rgba(10,10,10,0.88)] border border-[rgba(0,0,0,0.05)] dark:border-[rgba(255,255,255,0.15)] hover:bg-pink-400 hover:border-pink-400 text-black dark:text-white hover:text-white dark:hover:text-white hover:shadow-[0_4px_12px_rgba(244,114,182,0.4)] hover:scale-[1.01] rounded-xl font-medium cursor-pointer text-sm transition-all duration-300 active:scale-95 group transform-gpu"
            >
              Send message
              <svg
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="2.5"
                stroke="currentColor"
                class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-[2px] group-hover:-translate-y-[2px]"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25"></path>
              </svg>
            </button>
          </form>
        </div>
      </div>
      </div>
      <div class="flex-1"></div>
    </div>

    <div class="w-full">
      <Footer client:load currentLocale={Astro.currentLocale} />
    </div>
  </section>

  <style>
    .contact-buttons {
      display: flex;
      gap: 2.5rem;
    }

    .contact-button {
      display: flex;
      justify-content: center;
      align-items: center;
      width: 65px;
      height: 65px;
      border-radius: 50%;
      border: 1px solid rgba(0, 0, 0, 0.1);
      background-color: rgba(255, 255, 255, 0.9);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      cursor: pointer;
      transition: all 0.3s ease;
    }

    :global(.dark) .contact-button {
      border: 1px solid rgba(255, 255, 255, 0.15);
      background-color: rgba(10, 10, 10, 0.88);
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
      box-shadow: none;
    }

    .contact-button:hover {
      background-color: #000000;
      border-color: #000000;
      transform: scale(1.02);
    }

    :global(.dark) .contact-button:hover {
      background-color: #ffffff;
      border-color: #ffffff;
    }

    .contact-button img {
      width: 30px;
      height: 30px;
      filter: invert(0);
      transition: filter 0.3s ease;
    }

    :global(.dark) .contact-button img {
      filter: invert(1);
    }

    .contact-button:hover img {
      filter: invert(1);
    }

    :global(.dark) .contact-button:hover img {
      filter: invert(0);
    }

    .section-title {
      text-align: left;
    }

    @media (max-width: 768px) {
      .contact-buttons {
        gap: 1.5rem;
      }
      .contact-button {
        width: 60px;
        height: 60px;
      }
      .contact-button img {
        width: 25px;
        height: 25px;
      }

      .mobile-narrow {
        max-width: 95%;
        margin-left: auto;
        margin-right: auto;
        line-height: 1.7;
      }
    }

    @media (max-width: 1024px) {
      .desktop-indent {
        text-indent: 2em;
      }

      .mobile-narrow {
        margin-left: auto;
        margin-right: auto;
        line-height: 1.7;
      }
    }

    @media (min-width: 1025px) {
      .desktop-indent {
        text-indent: 4em;
      }
    }
  </style>
</Layout>

<script>
  // AJAX form submission for Web3Forms
  const form = document.getElementById("contact-form") as HTMLFormElement;
  const submitButton = document.getElementById(
    "submit-button",
  ) as HTMLButtonElement;

  if (form && submitButton) {
    form.addEventListener("submit", async function (e) {
      e.preventDefault();

      const originalButtonHtml = submitButton.innerHTML;
      submitButton.innerHTML = "Sending...";
      submitButton.disabled = true;
      submitButton.classList.add("opacity-70", "cursor-not-allowed");

      const formData = new FormData(form);
      const object = Object.fromEntries(formData);
      const json = JSON.stringify(object);

      try {
        const response = await fetch("https://api.web3forms.com/submit", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            Accept: "application/json",
          },
          body: json,
        });

        const result = await response.json();

        if (response.status == 200) {
          submitButton.innerHTML = `
            Message sent!
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4 text-green-500">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
            </svg>
          `;
          submitButton.classList.remove(
            "hover:bg-pink-400",
            "hover:border-pink-400",
            "hover:text-white",
            "dark:hover:text-white",
            "hover:shadow-[0_4px_12px_rgba(244,114,182,0.4)]",
            "hover:scale-[1.01]",
            "active:scale-95"
          );
          form.reset();
        } else {
          console.log(response);
          submitButton.innerHTML = originalButtonHtml;
          submitButton.disabled = false;
          submitButton.classList.remove("opacity-70", "cursor-not-allowed");
          alert(
            result.message ||
              "Something went wrong. Please try again or email me directly.",
          );
        }
      } catch (error) {
        console.log(error);
        submitButton.innerHTML = originalButtonHtml;
        submitButton.disabled = false;
        submitButton.classList.remove("opacity-70", "cursor-not-allowed");
        alert(
          "Something went wrong. Please check your connection and try again.",
        );
      }
    });
  }
</script>
