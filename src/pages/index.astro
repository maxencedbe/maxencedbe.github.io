      'contact.send': 'Envoyer le message',
    }
  };

  const formSubjects: Record<string, string> = {
    en: 'New message from your Portfolio',
    fr: 'Nouveau message depuis ton Portfolio',
  };

  function applyLocaleStatic(locale: string) {
    const t = translations[locale];
    if (!t) return;
    document.querySelectorAll('[data-i18n]').forEach((el) => {
      const key = (el as HTMLElement).dataset.i18n!;
      if (t[key] !== undefined) el.textContent = t[key];
    });
    const subjectEl = document.getElementById('form-subject') as HTMLInputElement | null;
    if (subjectEl) subjectEl.value = formSubjects[locale] || formSubjects.en;
  }

  window.switchLocale = async (newLocale: string) => {
    const els = [
      ...document.querySelectorAll('[data-i18n], [data-locale-fade]'),
      ...document.querySelectorAll('.card'),
    ] as HTMLElement[];

    // Pick the section closest to the top of the viewport as scroll anchor
    const sections = [...document.querySelectorAll('section')] as HTMLElement[];
    const anchor = sections.reduce((best, s) => {
      const top = s.getBoundingClientRect().top;
      const bestTop = best.getBoundingClientRect().top;
      return Math.abs(top) < Math.abs(bestTop) ? s : best;
    }, sections[0]);

    sections.forEach(s => {
      // section-bg-reveal sections have a ::before wave pseudo-element positioned
      // at top:-72px. Locking overflow:hidden clips it, and changing the inline
      // height style can restart the infinite CSS animation. Skip those sections
      // and let the scroll-correction handle any positional delta.
      if (s.classList.contains('section-bg-reveal')) return;
      s.style.height = s.offsetHeight + 'px';
      s.style.overflow = 'hidden';
    });

    // Lock widths before fade-out to prevent layout shift
    els.forEach(el => {
      const w = el.getBoundingClientRect().width;
      if (w > 0) { el.style.width = w + 'px'; el.style.boxSizing = 'border-box'; }
    });

    els.forEach(el => {
      el.style.transition = 'opacity 0.25s ease-in, filter 0.25s ease-in';
      el.style.opacity = '0';
      el.style.filter = 'blur(6px)';
    });
    await new Promise(r => setTimeout(r, 250));

    applyLocaleStatic(newLocale);
    localStorage.setItem('locale', newLocale);
    document.documentElement.lang = newLocale;
    document.documentElement.setAttribute('data-locale', newLocale);
    document.dispatchEvent(new CustomEvent('locale-change', { detail: { locale: newLocale } }));

    // Release width locks while invisible — layout reflows here, unseen
    els.forEach(el => { el.style.width = ''; el.style.boxSizing = ''; });

    await new Promise(r => requestAnimationFrame(() => requestAnimationFrame(r)));

    // Capture anchor position now (after React re-renders, sections still locked)
    // so the reference is fresh and not stale from before the 250ms fade-out.
    const anchorTopBefore = anchor.getBoundingClientRect().top;

    // Stop Lenis during correction so it can't override the scroll in the same frame
    const lenis = (window as any).lenis;
    if (lenis) lenis.stop();

    // Release + measure + correct scroll in one synchronous block — no paint between them
    sections.forEach(s => { s.style.height = ''; s.style.overflow = ''; });
    const delta = anchor.getBoundingClientRect().top - anchorTopBefore;
    if (delta !== 0) {
      window.scrollBy({ top: delta, behavior: 'instant' });
    }

    // Sync Lenis's virtual position and resume
    if (lenis) {
      lenis.targetScroll = window.scrollY;
      lenis.animatedScroll = window.scrollY;
      lenis.start();
    }

    await new Promise(r => setTimeout(r, 50));

    els.forEach(el => {
      el.style.transition = 'opacity 0.6s ease-out, filter 0.6s ease-out';
      el.style.opacity = '1';
      el.style.filter = 'blur(0px)';
    });
    await new Promise(r => setTimeout(r, 650));
    els.forEach(el => {
      el.style.transition = '';
      el.style.opacity = '';
      el.style.filter = '';
    });
  };

  // Apply on initial page load (no animation)
  const initialLocale = localStorage.getItem('locale') || 'en';
  if (initialLocale !== 'en') applyLocaleStatic(initialLocale);
  // Notify React components of initial locale
  document.dispatchEvent(new CustomEvent('locale-change', { detail: { locale: initialLocale } }));

  // Re-apply on Astro internal navigation
  document.addEventListener('astro:after-swap', () => {
    const locale = localStorage.getItem('locale') || 'en';
    if (locale !== 'en') applyLocaleStatic(locale);
    document.dispatchEvent(new CustomEvent('locale-change', { detail: { locale } }));
  });
</script>

<script>
  // ── Contact form ──────────────────────────────────────────────────────────
  const form = document.getElementById("contact-form") as HTMLFormElement;
  const submitButton = document.getElementById("submit-button") as HTMLButtonElement;

  if (form && submitButton) {
    form.addEventListener("submit", async function (e) {
      e.preventDefault();
      const locale = localStorage.getItem('locale') || 'en';
      const sendingLabel = locale === 'fr' ? 'Envoi en cours...' : 'Sending...';
      const successLabel = locale === 'fr' ? 'Message envoyé !' : 'Message sent!';
      const errorMsg = locale === 'fr'
        ? "Une erreur est survenue. Merci de réessayer ou de me contacter directement par email."
        : "Something went wrong. Please try again or email me directly.";
      const networkErrorMsg = locale === 'fr'
        ? "Une erreur de connexion est survenue. Merci de réessayer."
        : "Something went wrong. Please check your connection and try again.";

      const originalButtonHtml = submitButton.innerHTML;
      submitButton.innerHTML = sendingLabel;
      submitButton.disabled = true;
      submitButton.classList.add("opacity-70", "cursor-not-allowed");

      const formData = new FormData(form);
      const json = JSON.stringify(Object.fromEntries(formData));

      try {
        const response = await fetch("https://api.web3forms.com/submit", {
          method: "POST",
          headers: { "Content-Type": "application/json", Accept: "application/json" },
          body: json,
        });
        const result = await response.json();
        if (response.status == 200) {
          submitButton.innerHTML = `${successLabel} <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4 text-green-500"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>`;
          submitButton.classList.remove("hover:bg-pink-400", "hover:border-pink-400", "hover:text-white", "dark:hover:text-white", "hover:shadow-[0_4px_12px_rgba(244,114,182,0.4)]", "hover:scale-[1.01]", "active:scale-95");
          form.reset();
        } else {
          submitButton.innerHTML = originalButtonHtml;
          submitButton.disabled = false;
          submitButton.classList.remove("opacity-70", "cursor-not-allowed");
          alert(result.message || errorMsg);
        }
      } catch {
        submitButton.innerHTML = originalButtonHtml;
        submitButton.disabled = false;
        submitButton.classList.remove("opacity-70", "cursor-not-allowed");
        alert(networkErrorMsg);
      }
    });
  }
</script>
