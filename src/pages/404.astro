---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Page not found" showNavbar={false} isLocked={true}>
  <main class="flex flex-1 flex-col items-center justify-center text-center px-4">
    <h1 id="not-found-title" class="animate-type text-black dark:text-white md:text-6xl md:pb-2" style="opacity: 0; transition: opacity 0.2s">
      404 | Page not found
    </h1>
    <a
      id="back-button"
      href="/"
      class="back-button inline-flex items-center justify-center gap-2 px-8 py-3.5 bg-[rgba(0,0,0,0.02)] dark:bg-[rgba(10,10,10,0.88)] border border-[rgba(0,0,0,0.05)] dark:border-[rgba(255,255,255,0.15)] hover:bg-pink-400 hover:border-pink-400 text-black dark:text-white hover:text-white dark:hover:text-white hover:shadow-[0_4px_12px_rgba(244,114,182,0.4)] hover:scale-[1.01] rounded-xl font-medium text-sm no-underline transition-all duration-300 active:scale-95"
      style="opacity: 0"
    >
      Back to home page
    </a>
  </main>

  <script is:inline>
    const pathname = window.location.pathname;
    // Match the language the visitor picked on the rest of the site (stored in
    // localStorage), falling back to the URL prefix.
    const stored = (typeof localStorage !== "undefined" && localStorage.getItem("locale")) || null;
    const locale = stored || (pathname.startsWith("/fr") ? "fr" : "en");
    const title = document.getElementById("not-found-title");
    const button = document.getElementById("back-button");

    if (locale === "fr") {
      if (title) title.innerText = "404 | Page non trouvée";
      if (button) {
        button.innerText = "Retour à l'accueil";
        button.setAttribute("href", "/fr");
      }
      document.title = "Page non trouvée";
    }

    // Reveal elements after text update
    if (title) title.style.opacity = "1";
    if (button) button.style.opacity = "1";
  </script>

  <style>
    .animate-type {
      margin-bottom: 40px;
      position: relative;
    }

    .animate-type::after {
      content: "";
      position: absolute;
      top: 0;
      right: -12px;
      width: 4px;
      height: 1em;
      background: #000;
      animation: type 0.7s alternate infinite;
    }

    :global(.dark) .animate-type::after {
      background: #fff;
    }

    .animate-type::after {
      top: 0em;
      height: 1em;
    }

    @keyframes type {
      from {
        opacity: 1;
      }
      to {
        opacity: 0;
      }
    }

    @keyframes blink {
      to {
        visibility: hidden;
      }
    }

    @media (max-width: 1024px) {
      .animate-type {
        font-size: 2rem;
        margin-bottom: 5px;
      }
      .animate-type::after {
        content: "";
        position: absolute;
        right: -8px;
        width: 2px;
        height: 1em;
        background: #fff;
        animation: type 0.7s alternate infinite;

        top: 50%;
        transform: translateY(-90%);
      }
    }

    @media (max-width: 767px) {
      .animate-type {
        font-size: 2rem;
        margin-bottom: 20px;
      }
      .animate-type::after {
        content: "";
        position: absolute;
        right: -8px;
        width: 2px;
        height: 1em;
        background: #fff;
        animation: type 0.7s alternate infinite;

        top: 50%;
        transform: translateY(-50%);
      }
    }
  </style>
</Layout>
