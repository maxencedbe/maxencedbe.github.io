---
interface Props {
  flip?: boolean;
}
const { flip = false } = Astro.props;
---

<div class:list={["wave-block", flip && "wave-flip"]} aria-hidden="true">
  <svg
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 1440 72"
    preserveAspectRatio="none"
  >
    <defs>
      <linearGradient id="wave-grad" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%" class="wave-stop" stop-opacity="0" />
        <stop offset="100%" class="wave-stop" stop-opacity="1" />
      </linearGradient>
    </defs>
    <path fill="url(#wave-grad)" d="M0,36 C360,72 1080,0 1440,36 L1440,72 L0,72 Z" />
  </svg>
</div>

<style>
  .wave-block {
    display: block;
    height: 72px;
    overflow: hidden;
    pointer-events: none;
    margin-bottom: -1px;
  }
  .wave-flip {
    transform: scaleY(-1);
    margin-bottom: 0;
    margin-top: -1px;
  }
  svg {
    display: block;
    width: 100%;
    height: 100%;
  }
  /* Gradient: transparent → computed section-bg-reveal color, no double-transparency seam */
  :global(.wave-stop) {
    stop-color: #e4e4e4;
  }
  :global(html.dark) :global(.wave-stop) {
    stop-color: #202020;
  }
</style>
